# Google Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# Video Configuration
VIDEO_PATH=videos/test_video.mp4

# Device Configuration (cuda, cpu, or auto)
DEVICE=auto

# Detection Parameters
MOTION_THRESHOLD=2000
MAX_INVESTIGATION_ROUNDS=3

# Alert Frame Saving
SAVE_ALERTS=true
ALERTS_DIR=alerts
BUFFER_DURATION_SECONDS=10
CLEANUP_OLD_ALERTS_DAYS=7

# Firebase Cloud Messaging (FCM) for Mobile Notifications
ENABLE_FCM_NOTIFICATIONS=true
FIREBASE_CREDENTIALS_PATH=your-firebase-credentials.json
FCM_TOPIC=violence_alerts
